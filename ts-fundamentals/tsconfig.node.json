{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["vite.config.ts"]
}

// Separate config for vite.config.ts that includes "node" types.
// This way the Vite config gets Node.js type checking while the app code stays clean.
